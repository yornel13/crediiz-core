          "name": "Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/dashboard/summary",
              "host": ["{{baseUrl}}"],
              "path": ["api", "dashboard", "summary"],
              "query": [
                { "key": "from", "value": "2025-01-01", "disabled": true },
                { "key": "to", "value": "2025-12-31", "disabled": true }
              ]
            },
            "description": "Roles: ADMIN. Query: from?, to? (ISO date)."
          }
        },
        {
          "name": "Agent dashboard",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/dashboard/agent/{{agentId}}",
