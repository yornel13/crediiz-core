{
  "info": {
    "_postman_id": "3f9a2b7c-1e4d-4a88-b6c1-panama-calls-core",
    "name": "Panama Calls Core API",
    "description": "Complete endpoint suite for the panama-calls-core NestJS API.\n\n## Setup\n1. Set the collection variable `baseUrl` (default: http://localhost:3000)\n2. Run **Auth → Login** with valid credentials — the response's `accessToken` is auto-saved to the `accessToken` collection variable\n3. All protected requests use `Bearer {{accessToken}}` automatically via collection-level auth\n\n## Auth scheme\nJWT Bearer. Header: `Authorization: Bearer <token>`.\n\n## Global prefix\nAll routes live under `/api` EXCEPT `/health`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{accessToken}}", "type": "string" }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "agentId", "value": "", "type": "string" },
    { "key": "clientId", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Healthcheck",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            },
            "description": "Liveness + MongoDB connection state. Used by Railway healthcheck."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "const token = res?.data?.accessToken ?? res?.accessToken;",
                  "if (token) {",
                  "  pm.collectionVariables.set('accessToken', token);",
                  "  console.log('accessToken saved to collection variable');",
                  "} else {",
                  "  console.warn('No accessToken in response');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@example.com\",\n  \"password\": \"ChangeMe123!\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Public. Returns `{ accessToken }`. The test script stores it into `{{accessToken}}`."
          }
        }
      ]
    },
    {
      "name": "Admins",
      "item": [
        {
          "name": "List admins",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/admins",
              "host": ["{{baseUrl}}"],
              "path": ["api", "admins"]
            },
            "description": "Roles: ADMIN."
          }
        }
      ]
    },
    {
      "name": "Agents",
      "item": [
        {
          "name": "Create agent",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Agent\",\n  \"email\": \"agent@example.com\",\n  \"password\": \"StrongPass123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/agents",
              "host": ["{{baseUrl}}"],
              "path": ["api", "agents"]
            },
            "description": "Roles: ADMIN. Body: CreateAgentDto { name, email, password (min 8) }."
          }
        },
        {
          "name": "List agents",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/agents",
              "host": ["{{baseUrl}}"],
              "path": ["api", "agents"]
            },
            "description": "Roles: ADMIN."
          }
        },
        {
          "name": "Get agent by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/agents/{{agentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "agents", "{{agentId}}"]
            },
            "description": "Roles: ADMIN."
          }
        },
        {
          "name": "Update agent",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Renamed\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/agents/{{agentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "agents", "{{agentId}}"]
            },
            "description": "Roles: ADMIN. Body: UpdateAgentDto (all optional): { name?, password? (min 8), isActive? }."
          }
        }
      ]
    },
    {
      "name": "Clients",
      "item": [
        {
          "name": "Upload clients (Excel)",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": [] }
              ]
            },
            "url": {
              "raw": "{{baseUrl}}/api/clients/upload",
              "host": ["{{baseUrl}}"],
              "path": ["api", "clients", "upload"]
            },
            "description": "Roles: ADMIN. Multipart form-data. Field name: `file`. Select an .xlsx file.\n\n## Recognized headers (case-insensitive)\nFlat fields:\n- `name` | `nombre` (required)\n- `phone` | `telefono` | `teléfono` | `celular` (required)\n- `cedula` | `cédula` (optional)\n- `ss` | `s.s` | `seguro social` | `ssNumber` (optional)\n- `salary` | `salario` (optional)\n\nAny other column is preserved into `extraData`.\n\n## Response\n```json\n{\n  \"uploadBatchId\": \"<uuid>\",\n  \"insertedCount\": 348,\n  \"rejectedCount\": 1,\n  \"rejected\": [{ \"index\": 7, \"field\": \"cedula\", \"value\": \"8-1-1\", \"reason\": \"duplicate\" }]\n}\n```\nDuplicates on `cedula` or `ssNumber` do not abort the batch — they are reported in `rejected`."
          }
        },
        {
          "name": "Create client",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"María González\",\n  \"phone\": \"+507 6680-1776\",\n  \"cedula\": \"8-123-456\",\n  \"ssNumber\": \"034-1234\",\n  \"salary\": 1200,\n  \"extraData\": { \"bank\": \"Banco General\" }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/clients",
              "host": ["{{baseUrl}}"],
              "path": ["api", "clients"]
            },
            "description": "Roles: ADMIN. Body: CreateClientDto. Required: `name`, `phone`. Optional: `cedula`, `ssNumber`, `salary`, `extraData`. Returns 409 if `cedula` or `ssNumber` already exist."
          }
        },
        {
          "name": "List clients",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/clients?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["api", "clients"],
              "query": [
                { "key": "status", "value": "PENDING", "disabled": true, "description": "PENDING | INTERESTED | CONVERTED | REJECTED | INVALID_NUMBER | DO_NOT_CALL" },
                { "key": "assignedTo", "value": "", "disabled": true, "description": "Agent MongoId" },
                { "key": "uploadBatchId", "value": "", "disabled": true },
                { "key": "search", "value": "", "disabled": true, "description": "Free-text — matches name, cedula, ssNumber and phoneNormalized (digits-only)" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            },
            "description": "Roles: ADMIN. Query: ClientFilterDto (all optional). `assignedTo` is populated with `{ name, email }` in the response."
          }
        },
        {
          "name": "Get client by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/clients/{{clientId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "clients", "{{clientId}}"]
            },
            "description": "Roles: ADMIN. Returns the full client document with `assignedTo` populated."
          }
        },
        {
          "name": "List interested clients",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/clients/interested",
              "host": ["{{baseUrl}}"],
              "path": ["api", "clients", "interested"],
              "query": [
                { "key": "agentId", "value": "", "disabled": true }
              ]
            },
            "description": "Roles: ADMIN. Query: agentId? (string)."
          }
        },
        {
          "name": "List assigned to me (agent)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/clients/assigned",
              "host": ["{{baseUrl}}"],
              "path": ["api", "clients", "assigned"],
              "query": [
                { "key": "status", "value": "PENDING", "disabled": true }
              ]
            },
            "description": "Roles: AGENT. Returns clients assigned to the authenticated agent."
          }
        },
        {
          "name": "Assign clients to agent",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agentId\": \"{{agentId}}\",\n  \"clientIds\": [\"{{clientId}}\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/clients/assign",
              "host": ["{{baseUrl}}"],
              "path": ["api", "clients", "assign"]
            },
            "description": "Roles: ADMIN. Body: AssignClientsDto { agentId, clientIds[] }."
          }
        },
        {
          "name": "Update client",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"María González Pérez\",\n  \"phone\": \"+507 6680-1799\",\n  \"cedula\": \"8-123-456\",\n  \"ssNumber\": \"034-1234\",\n  \"salary\": 1500,\n  \"extraData\": { \"bank\": \"Banco General\" }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/clients/{{clientId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "clients", "{{clientId}}"]
            },
            "description": "Roles: ADMIN. Body: UpdateClientDto (all fields optional). Updating `phone` recomputes `phoneNormalized` server-side. Returns 409 if `cedula` or `ssNumber` collide with another client."
          }
        },
        {
          "name": "Update client status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"INTERESTED\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/clients/{{clientId}}/status",
              "host": ["{{baseUrl}}"],
              "path": ["api", "clients", "{{clientId}}", "status"]
            },
            "description": "Roles: ADMIN. Body: UpdateClientStatusDto { status: ClientStatus }."
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
